# 复制本文件为 .env.local，再填写自己的凭据：
# Windows PowerShell: Copy-Item .env.example .env.local
# macOS / Linux:      cp .env.example .env.local
#
# 安全要求：只提交 .env.example，绝对不要提交 .env.local。

# -----------------------------------------------------------------------------
# 1) 火山方舟大模型：复杂座舱意图与闲聊兜底
# 获取地址：https://console.volcengine.com/ark
# -----------------------------------------------------------------------------
ARK_API_KEY=
CHAT_DOUBAO_MODEL=doubao-seed-2-0-mini-260215

# -----------------------------------------------------------------------------
# 2) OCC 乘员感知 VLM：年龄、性别、低置信表情等视觉兜底
#
# 方案 A（默认、同事最容易配置）：doubao
# - 使用上面的 ARK_API_KEY
# - CHAT_VISION_MODEL 必须填写账号中已开通、支持图片输入的模型/Endpoint ID
#
# 方案 B：vllm
# - 使用自己可访问的 OpenAI-compatible /v1 服务
# - 不要把公司内网地址或真实 API Key 提交到仓库
# -----------------------------------------------------------------------------
OCC_VISION_BACKEND=doubao
# CHAT_VISION_MODEL=your-vision-model-or-endpoint-id

# 使用 vllm 时取消下面几行的注释并填写自己的服务：
# OCC_VLLM_BASE_URL=http://your-vllm-host:port/v1
# OCC_VLLM_MODEL=/path/or/model-name
# OCC_VLLM_API_KEY=
# OCC_VLLM_TIMEOUT_SEC=45

# -----------------------------------------------------------------------------
# 3) 本地离线 ASR（FunASR，不需要 API Key）
# 首次运行会从 ModelScope 下载模型并缓存到用户目录。
# -----------------------------------------------------------------------------
FUNASR_OFFLINE_MODEL=paraformer-zh
# 可选：SeACo Paraformer 领域热词，空格分隔
FUNASR_HOTWORDS=虚拟座舱 导航 超车 空调 除雾 生椰拿铁 橙C美式 摩卡 风景打卡

# -----------------------------------------------------------------------------
# 4) 本地意图初筛（不需要 API Key）
# sentence-transformers 首次使用会下载开源 embedding 模型。
# 未安装/下载失败时会自动退化为本地字符串模糊匹配。
# -----------------------------------------------------------------------------
INTENT_LOCAL_ENABLED=1
INTENT_LOCAL_MODEL=shibing624/text2vec-base-chinese
INTENT_LOCAL_THRESHOLD=0.58
INTENT_LOCAL_MARGIN=0.03
INTENT_LOCAL_PRELOAD=0

# -----------------------------------------------------------------------------
# 5) 火山引擎语音合成 TTS
# 获取地址：https://console.volcengine.com/speech/service
# 不配置时，座舱画面仍可运行，但不会生成在线语音播报。
# -----------------------------------------------------------------------------
VOLC_TTS_APP_ID=
VOLC_TTS_ACCESS_TOKEN=
VOLC_TTS_SECRET_KEY=
VOLC_TTS_VOICE_TYPE=zh_female_sajiaonvyou_moon_bigtts
# VOLC_TTS_URL=https://openspeech.bytedance.com/api/v1/tts
# VOLC_TTS_CLUSTER=volcano_tts
